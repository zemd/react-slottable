{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@zemd/tsconfig/tsconfig-react.json",
  "compilerOptions": {
    "types": ["node", "react", "react-dom"],
    "noPropertyAccessFromIndexSignature": false,
    "jsx": "preserve"
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
