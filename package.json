{
  "name": "@zemd/react-slottable",
  "type": "module",
  "version": "4.0.3",
  "license": "Apache-2.0",
  "description": "A lightweight concept to customize subcomponents in React",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "author": {
    "name": "Dmytro Zelenetskyi",
    "email": "dmytro.zelenetskyi@gmail.com",
    "url": "https://zemd.dev"
  },
  "homepage": "https://github.com/zemd/react-slottable",
  "repository": {
    "type": "git",
    "url": "https://github.com/zemd/react-slottable.git"
  },
  "bugs": {
    "url": "https://github.com/zemd/react-slottable/issues"
  },
  "keywords": [
    "react",
    "component",
    "subcomponent",
    "library",
    "slottable",
    "slots",
    "deeply customized"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --minify",
    "test": "vitest --run",
    "changeset": "changeset",
    "release": "changeset publish",
    "prepare": "husky",
    "lint": "eslint \"**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@swc/core": "1.15.33",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@zemd/eslint-react": "3.0.3",
    "@zemd/tsconfig": "2.0.0",
    "eslint": "10.3.0",
    "happy-dom": "20.9.0",
    "husky": "9.1.7",
    "prettier": "3.8.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tsdown": "0.21.10",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
